# Copy this file to `.env` and fill in the real values.
# `.env` is gitignored — it must NEVER be committed.

# --- Screener authentication ---------------------------------------------
# This account uses "Sign in with Google", so there is no password to automate.
# Instead paste the browser session cookie:
#   1. Log in to https://www.screener.in in your browser.
#   2. Open DevTools -> Application -> Cookies -> https://www.screener.in
#   3. Copy the value of the "sessionid" cookie and paste it below.
# The cookie lasts a few weeks; when it expires the pipeline prints a clear
# "cookie expired" message and you re-paste a fresh one.
SCREENER_SESSION_COOKIE=

# Optional: screener also sets a "csrftoken" cookie. Not required for the
# export download, but paste it here if a future endpoint needs it.
SCREENER_CSRF_TOKEN=

# --- Database -------------------------------------------------------------
DATABASE_URL=postgresql+psycopg://screener:screener@localhost:5432/screener

# --- Claude API (used from Milestone 5 for the 3-year summary) ------------
ANTHROPIC_API_KEY=

# --- Behaviour tuning -----------------------------------------------------
# Seconds to wait between company downloads, to stay polite to screener.
SCREENER_REQUEST_DELAY=3
# Prefer consolidated statements when a company reports them.
SCREENER_PREFER_CONSOLIDATED=true
